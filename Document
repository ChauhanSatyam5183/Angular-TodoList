   constructor(@Inject(PLATFORM_ID) private platformId: Object) {}

  ngOnInit() {
    if (isPlatformBrowser(this.platformId)) {   

      const localitem = localStorage.getItem("todos");

      if (localitem == null) {
        this.todos = [];
      } else {
        this.todos = JSON.parse(localitem);
      }
    }
  }
