    {{todo.sno}} - {{todo.title}}-{{todo.description}}
  </li>
</ul>


############## if else in angular
<div *ngIf="todos.length > 0; else noTodos">

  <div *ngFor="let todo of todos">
    <app-todo-item 
      [todo]="todo"
      (todoDelete)="deleteTodo($event)">
    </app-todo-item>
  </div>

</div>

<!-- else block -->
<ng-template #noTodos>
  <h4>No Todos to display</h4>
</ng-template>



